APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Local Herd: use https:// after `herd secure meal-craft`, or http:// if not secured
APP_URL=https://meal-craft.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database (or redis): run `php artisan queue:work` or `composer run dev` (includes queue:listen). Batch/analysis jobs need a worker.
# On APP_ENV=local, single-row "Enrich" in the library runs inline (dispatchSync) so Herd works without a worker; staging/production use the real queue.
# sync: PHPUnit uses sync; all jobs run in-process.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

USDA_API_KEY=

# Meal Craft Analysis (Gemini + Edamam + USDA)
# Gemini: create a key at https://aistudio.google.com/apikey (Gemini API / generativelanguage.googleapis.com).
# Do not use OAuth client secrets. One line, no quotes. Prefer GOOGLE_GEMINI_KEY; GEMINI_API_KEY is a fallback.
GOOGLE_GEMINI_KEY=
GEMINI_API_KEY=
# Stable Flash for text/JSON; see https://ai.google.dev/gemini-api/docs/models/gemini
GEMINI_MODEL=gemini-2.5-flash
# Set true to use scripts/gemini-ingredient-reasoning.mjs (@google/generative-ai) instead of REST
GEMINI_USE_NODE_SDK=false
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

CALORIEKING_API_TOKEN=
CALORIEKING_BASE_URL=https://foodapi.calorieking.com/v1

VITE_APP_NAME="${APP_NAME}"
